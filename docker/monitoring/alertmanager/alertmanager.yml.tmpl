global:
  resolve_timeout: 5m

route:
  receiver: ops-inbox
  group_by: ["alertname", "severity"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h

receivers:
  # Alerts are evaluated here and visible in Prometheus/Alertmanager.
  # Email delivery is handled by CloudWatch → SNS (wired in Terraform).
  - name: ops-inbox

inhibit_rules:
  - source_matchers: [severity="critical"]
    target_matchers: [severity="warning"]
    equal: [alertname]
